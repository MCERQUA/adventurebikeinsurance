# No API keys required for the file-based contact form fallback.
# If you want email notifications on form submissions, configure one of these:

# Option 1: Resend
# RESEND_API_KEY=re_xxxxx
# CONTACT_EMAIL=josh@contractorschoiceagency.com

# Option 2: AgentMail
# AGENTMAIL_API_KEY=your_key
# AGENTMAIL_INBOX_ID=your_inbox_id
